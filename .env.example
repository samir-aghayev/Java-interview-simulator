# Copy to .env and fill in real values before running `docker compose up` for anything beyond
# local experimentation. docker-compose.yml falls back to insecure development defaults for
# anything left unset here.

DB_PASSWORD=interview_app_pw

# Required for real deployments — generate with e.g. `openssl rand -base64 48`.
JWT_SECRET=dev-only-insecure-secret-please-override-in-production-1234567890
JWT_EXPIRATION_MINUTES=1440

# Bootstraps the first admin account on startup (promotes the account if it already exists).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Used to build links (password reset emails, OAuth redirects). Point at wherever the app is
# actually reachable from a browser.
FRONTEND_URL=http://localhost:8080

# Google OAuth login stays disabled until both of these are set — see CLAUDE.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
